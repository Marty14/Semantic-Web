<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/martibra/ontologies/2025/11/untitled-ontology-2/"
     xml:base="http://www.semanticweb.org/martibra/ontologies/2025/11/untitled-ontology-2/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:cybersOnto="http://www.semanticweb.org/martibra/ontologies/cybersOnto#">
     
    <owl:Ontology rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto"/>

    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#performs">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#ThreatActor"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Attack"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#isPerformedBy">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#performs"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#storesAsset">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#System"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#InformationAsset"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#targets">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Attack"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#InformationAsset"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#protects">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Mitigation"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#System"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#dependsOn">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#System"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#System"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#communicatesWith">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#System"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#System"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#attacks">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#ThreatActor"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#System"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#exploits">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Attack"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Vulnerability"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#hasVulnerability">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#System"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Vulnerability"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#mitigates">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Mitigation"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Vulnerability"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#isMitigatedBy">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#mitigates"/>
    </owl:ObjectProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#hasOS">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#System"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#hasPortNumber">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#System"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#dataValue">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#InformationAsset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#hasCVSSScore">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Vulnerability"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#hasIPAddress">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#System"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Attack">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#exploits"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Vulnerability"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#targets"/>
                <owl:allValuesFrom rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#InformationAsset"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#RiskLevel"/>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#System">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#hasIPAddress"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#ThreatActor">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#performs"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Attack"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Vulnerability"/>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Mitigation">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#mitigates"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Vulnerability"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#protects"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#System"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Server">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#System"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Workstation">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#System"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#NetworkDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#System"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Firewall">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#NetworkDevice"/>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#TechnicalControl"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#HighRiskSystem">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#System"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#hasVulnerability"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Vulnerability"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#System"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#CriticalAttack">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Attack"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#exploits"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#CriticalVulnerability"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Attack"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#SecureSystem">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#System"/>
                    <owl:Class>
                        <owl:complementOf>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#hasVulnerability"/>
                                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Vulnerability"/>
                            </owl:Restriction>
                        </owl:complementOf>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#System"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#CriticalVulnerability">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Vulnerability"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#hasCVSSScore"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#float">8.0</xsd:minInclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Vulnerability"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#SoftwareVulnerability">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Vulnerability"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#ZeroDayVulnerability">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Vulnerability"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#AdministrativeControl">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Mitigation"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#PhysicalControl">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Mitigation"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#TechnicalControl">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Mitigation"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Malware">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Attack"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Ransomware">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Attack"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Low">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#RiskLevel"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Medium">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#RiskLevel"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#High">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#RiskLevel"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Critical">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#RiskLevel"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Hacker">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#ThreatActor"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Insider">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#ThreatActor"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#NationState">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#ThreatActor"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#ScriptKiddie">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#ThreatActor"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#DatabaseServer">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Server"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#WebServer">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Server"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#ApplicationServer">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Server"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Router">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#NetworkDevice"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Switch">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#NetworkDevice"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#IoTSensor">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#NetworkDevice"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#MobileDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#System"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#CloudInstance">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#System"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Phishing">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Attack"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#DDoS">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Attack"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#SQLInjection">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Attack"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#CrossSiteScripting">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Attack"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#ManInTheMiddle">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Attack"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#SocialEngineering">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Attack"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#BruteForce">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Attack"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Antivirus">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#TechnicalControl"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#IntrusionDetectionSystem">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#TechnicalControl"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#IntrusionPreventionSystem">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/martibra/ontologies/cybersOnto#TechnicalControl"/>
    </owl:Class>
    <owl:Class rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto#Encryption">
