<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://www.semanticweb.org/martibra/ontologies/cybersOnto"
         xmlns="http://www.semanticweb.org/martibra/ontologies/cybersOnto#">

<owl:Ontology rdf:about="http://www.semanticweb.org/martibra/ontologies/cybersOnto"/>

<owl:ObjectProperty rdf:about="#performs">
  <rdfs:domain rdf:resource="#ThreatActor"/>
  <rdfs:range rdf:resource="#Attack"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isPerformedBy">
  <owl:inverseOf rdf:resource="#performs"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#storesAsset">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
  <rdfs:domain rdf:resource="#System"/>
  <rdfs:range rdf:resource="#InformationAsset"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#targets">
  <rdfs:domain rdf:resource="#Attack"/>
  <rdfs:range rdf:resource="#InformationAsset"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#protects">
  <rdfs:domain rdf:resource="#Mitigation"/>
  <rdfs:range rdf:resource="#System"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#dependsOn">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
  <rdfs:domain rdf:resource="#System"/>
  <rdfs:range rdf:resource="#System"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#communicatesWith">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
  <rdfs:domain rdf:resource="#System"/>
  <rdfs:range rdf:resource="#System"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#attacks">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
  <rdfs:domain rdf:resource="#ThreatActor"/>
  <rdfs:range rdf:resource="#System"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#exploits">
  <rdfs:domain rdf:resource="#Attack"/>
  <rdfs:range rdf:resource="#Vulnerability"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasVulnerability">
  <rdfs:domain rdf:resource="#System"/>
  <rdfs:range rdf:resource="#Vulnerability"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#mitigates">
  <rdfs:domain rdf:resource="#Mitigation"/>
  <rdfs:range rdf:resource="#Vulnerability"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isMitigatedBy">
  <owl:inverseOf rdf:resource="#mitigates"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#hasOS">
  <rdfs:domain rdf:resource="#System"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasPortNumber">
  <rdfs:domain rdf:resource="#System"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#dataValue">
  <rdfs:domain rdf:resource="#InformationAsset"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasCVSSScore">
  <rdfs:domain rdf:resource="#Vulnerability"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasIPAddress">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#System"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>

<owl:Class rdf:about="#ThreatActor">
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#performs"/>
      <owl:someValuesFrom rdf:resource="#Attack"/>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#Attack">
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#exploits"/>
      <owl:someValuesFrom rdf:resource="#Vulnerability"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#targets"/>
      <owl:allValuesFrom rdf:resource="#InformationAsset"/>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#System">
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasIPAddress"/>
      <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
      <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#InformationAsset"/>

<owl:Class rdf:about="#Mitigation">
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#mitigates"/>
      <owl:someValuesFrom rdf:resource="#Vulnerability"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#protects"/>
      <owl:someValuesFrom rdf:resource="#System"/>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#Vulnerability"/>

<owl:Class rdf:about="#RiskLevel"/>

<owl:Class rdf:about="#Server">
  <rdfs:subClassOf rdf:resource="#System"/>
</owl:Class>

<owl:Class rdf:about="#Workstation">
  <rdfs:subClassOf rdf:resource="#System"/>
</owl:Class>

<owl:Class rdf:about="#NetworkDevice">
  <rdfs:subClassOf rdf:resource="#System"/>
</owl:Class>

<owl:Class rdf:about="#Firewall">
  <rdfs:subClassOf rdf:resource="#NetworkDevice"/>
  <rdfs:subClassOf rdf:resource="#TechnicalControl"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#mitigates"/>
      <owl:allValuesFrom rdf:resource="#NetworkVulnerability"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#protects"/>
      <owl:onClass rdf:resource="#System"/>
      <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#TechnicalControl">
  <rdfs:subClassOf rdf:resource="#Mitigation"/>
</owl:Class>

<owl:Class rdf:about="#HighRiskSystem">
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#System"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#hasVulnerability"/>
          <owl:someValuesFrom rdf:resource="#Vulnerability"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
  <rdfs:subClassOf rdf:resource="#System"/>
</owl:Class>

<owl:Class rdf:about="#CriticalAttack">
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Attack"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#exploits"/>
          <owl:someValuesFrom rdf:resource="#CriticalVulnerability"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
  <rdfs:subClassOf rdf:resource="#Attack"/>
</owl:Class>

<owl:Class rdf:about="#CriticalVulnerability">
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Vulnerability"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#hasCVSSScore"/>
          <owl:someValuesFrom>
            <rdfs:Datatype>
              <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
              <owl:withRestrictions>
                <rdf:Description>
                  <rdf:first>
                    <rdf:Description>
                      <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#float">8.0</xsd:minInclusive>
                    </rdf:Description>
                  </rdf:first>
                  <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                </rdf:Description>
              </owl:withRestrictions>
            </rdfs:Datatype>
          </owl:someValuesFrom>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
  <rdfs:subClassOf rdf:resource="#Vulnerability"/>
</owl:Class>

<owl:Class rdf:about="#SecureSystem">
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#System"/>
        <owl:Class>
          <owl:complementOf>
            <owl:Restriction>
              <owl:onProperty rdf:resource="#hasVulnerability"/>
              <owl:someValuesFrom rdf:resource="#Vulnerability"/>
            </owl:Restriction>
          </owl:complementOf>
        </owl:Class>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
  <rdfs:subClassOf rdf:resource="#System"/>
</owl:Class>

<owl:Class rdf:about="#SoftwareVulnerability">
  <rdfs:subClassOf rdf:resource="#Vulnerability"/>
</owl:Class>

